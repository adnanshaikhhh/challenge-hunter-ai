# Required: Telegram bot (free, primary notification channel)
# Create one by messaging @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Discord webhook (free, secondary)
# Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Optional: ntfy.sh topic (free, push notifications to phone)
# Subscribe on your phone via the ntfy app.
NTFY_TOPIC=

# Optional: OpenAI for richer AI analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: OpenRouter for AI code generation (supports MiniMax, Claude, GPT-4, etc.)
# Get a key at https://openrouter.ai/keys — one key works for many models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
# Optional: custom OpenAI-compatible base URL
# - OpenRouter (default): https://openrouter.ai/api/v1/chat/completions
# - NVIDIA NIM:        https://integrate.api.nvidia.com/v1/chat/completions
# - Custom MiniMax:     https://your-minimax-proxy.com/v1/chat/completions
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Optional: GitHub PAT for autonomous repo creation
# Settings → Developer Settings → Personal Access Tokens (classic, repo scope)
GITHUB_TOKEN=
GITHUB_USERNAME=

# App settings
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string
SCAN_INTERVAL_HOURS=4
MIN_PRIZE_USD=500
MIN_SCORE_FOR_ALERT=70
PORT=5000
