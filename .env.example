# =============================================================================
# Challenge Hunter AI v2.2 — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ----- Notifications (free, all optional) -----
# Telegram bot (primary)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord webhook (secondary)
DISCORD_WEBHOOK_URL=
# ntfy.sh topic (tertiary, phone push)
NTFY_TOPIC=

# ----- LLM Provider (REQUIRED for AI features) -----
# PRIMARY: tokenrouter.com (custom endpoint, supports Minimax M3)
LLM_PRIMARY_BASE_URL=https://api.tokenrouter.com/v1
LLM_PRIMARY_KEY=
LLM_PRIMARY_MODEL=MiniMax-M3

# FALLBACK: NVIDIA NIM (free credits at build.nvidia.com)
LLM_FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_FALLBACK_KEY=
LLM_FALLBACK_MODEL=meta/llama-3.1-70b-instruct

# TERTIARY: OpenAI (paid, optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ----- GitHub (for autonomous repo creation) -----
GITHUB_TOKEN=
GITHUB_USERNAME=

# ----- Deployment platforms (for 🚀 Deploy) -----
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
VERCEL_TOKEN=

# ----- App settings -----
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string
SCAN_INTERVAL_HOURS=4
MIN_PRIZE_USD=500
MIN_SCORE_FOR_ALERT=70
PORT=5000

# ----- Database -----
# DB_PATH=./opportunities.db  # Optional: override DB location
